generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  role          String         @default("driver")
  pin           String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  dailyReviews  DailyReview[]
  weeklyReviews WeeklyReview[]
  shortcuts     UserShortcut[]
}

model UserShortcut {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // print_weekly | weekly_check | daily_check
  vehicleId String?
  label     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model VehicleType {
  id       String    @id @default(cuid())
  name     String    @unique
  order    Int       @default(0)
  features Json?
  vehicles Vehicle[]
}

model Vehicle {
  id                   String            @id @default(cuid())
  plate                String            @unique
  brand                String
  model                String
  year                 Int
  color                String?
  kmCurrent            Int               @default(0)
  notes                String?           @db.Text
  weeklyFluidItems     Json?
  weeklyInventoryItems Json?
  typeId               String?
  type                 VehicleType?      @relation(fields: [typeId], references: [id])
  warrantyExpiry       DateTime?
  insuranceCompany     String?
  policyNumber         String?
  policyStartDate      DateTime?
  policyExpirationDate DateTime?
  policyPdfUrl         String?
  policyPdfName        String?
  policyPdfUploadedAt  DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  oilChange        OilChange?
  vtv              VTV?
  fireExtinguisher FireExtinguisher?
  tirePressure     TirePressure?
  alignmentBalance AlignmentBalance?
  tools            Tool[]
  fluids           Fluid[]
  dailyReviews     DailyReview[]
  weeklyReviews    WeeklyReview[]
  links            CustomLink[]
  trailers         Trailer[]
  trailerUnits     TrailerUnit[]
  drivers          Driver[]
}

model Trailer {
  id            String   @id @default(cuid())
  // Identificación
  domain        String   @unique
  brand         String
  model         String
  year          Int
  chassisNumber String?
  // Configuración
  trailerType   String   // "acoplado" | "semiremolque"
  subtype       String
  axleCount     Int?
  axleConfig    String?
  grossWeight   Float?
  tare          Float?
  notes         String?  @db.Text
  // Asociación
  vehicleId     String?
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  drivers       Driver[]
}

model TrailerUnit {
  id           String               @id @default(cuid())
  companyId    String?
  name         String
  patent       String?
  brand        String?
  model        String?
  year         Int?
  serialNumber String?
  description  String?              @db.Text
  status       String               @default("ACTIVE")
  vehicleId    String?
  vehicle      Vehicle?             @relation(fields: [vehicleId], references: [id])
  documents    TrailerDocument[]
  maintenances TrailerMaintenance[]
  inspections  TrailerInspection[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model TrailerMaintenance {
  id           String      @id @default(cuid())
  trailerId    String
  trailer      TrailerUnit @relation(fields: [trailerId], references: [id], onDelete: Cascade)
  type         String      @default("engrase")
  date         DateTime
  responsible  String?
  observations String?     @db.Text
  nextDueDate  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model TrailerInspection {
  id            String      @id @default(cuid())
  trailerId     String
  trailer       TrailerUnit @relation(fields: [trailerId], references: [id], onDelete: Cascade)
  date          DateTime
  inspector     String?
  generalResult String      @default("ok")
  observations  String?     @db.Text
  tires         String      @default("ok")
  tiresNote     String?
  lights        String      @default("ok")
  lightsNote    String?
  hitch         String      @default("ok")
  hitchNote     String?
  chains        String      @default("ok")
  chainsNote    String?
  brakes        String      @default("ok")
  brakesNote    String?
  cleaning      String      @default("ok")
  cleaningNote  String?
  woodFloor     String      @default("ok")
  woodFloorNote String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model TrailerDocument {
  id             String      @id @default(cuid())
  trailerId      String
  trailer        TrailerUnit @relation(fields: [trailerId], references: [id], onDelete: Cascade)
  name           String
  type           String
  issueDate      DateTime?
  expiryDate     DateTime?
  fileUrl        String?
  fileName       String?
  fileUploadedAt DateTime?
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AlignmentBalance {
  id          String    @id @default(cuid())
  vehicleId   String    @unique
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  lastKm      Int
  lastDate    DateTime
  kmInterval  Int       @default(20000)
  nextKm      Int?
  nextDate    DateTime?
  notes       String?   @db.Text
  updatedAt   DateTime  @updatedAt
}

model FireExtinguisher {
  id             String   @id @default(cuid())
  vehicleId      String   @unique
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expirationDate DateTime
  notes          String?  @db.Text
  updatedAt      DateTime @updatedAt
}

model Fluid {
  id          String    @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  expiryMode  String    @default("date")
  kmInterval  Int?
  lastKm      Int?
  nextKm      Int?
  lastDate    DateTime?
  nextDate    DateTime?
  notes              String?   @db.Text
  showMaintenanceBtn Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model OilChange {
  id            String    @id @default(cuid())
  vehicleId     String    @unique
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  kmInterval    Int       @default(10000)
  lastKm        Int
  lastDate      DateTime
  nextKm        Int
  nextDate      DateTime?
  oilType           String?
  airFilterCleaned  Boolean   @default(false)
  airFilterChanged  Boolean   @default(false)
  fuelFilterChanged Boolean   @default(false)
  notes             String?   @db.Text
  updatedAt     DateTime  @updatedAt
}

model VTV {
  id             String    @id @default(cuid())
  vehicleId      String    @unique
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expirationDate DateTime
  lastDate       DateTime?
  notes          String?   @db.Text
  updatedAt      DateTime  @updatedAt
}

model TirePressure {
  id          String    @id @default(cuid())
  vehicleId   String    @unique
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  frontLeft   Float?
  frontRight  Float?
  rearLeft    Float?
  rearRight   Float?
  spare       Float?
  recommended Float     @default(32)
  lastCheck   DateTime  @default(now())
  notes       String?   @db.Text
  updatedAt   DateTime  @updatedAt
}

model Tool {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int      @default(1)
  condition String   @default("good")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyReview {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  reviewer  String?
  items     Json
  kmReading Int?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
}

model WeeklyReview {
  id              String   @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  weekStart       DateTime
  reviewer        String?
  kmReading       Int?
  insuranceOk     Boolean?
  items           Json?
  fluidChecks     Json?
  inventoryChecks Json?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
}

model CustomLink {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  label     String
  url       String   @db.Text
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Driver {
  id               String    @id @default(cuid())
  // Personal
  fullName         String
  dni              String?
  cuil             String?
  birthDate        DateTime?
  address          String?   @db.Text
  phone            String?
  emergencyContact String?
  // License
  licenseCategories  Json?
  licenseExpiry      DateTime?
  licensePhotoFront  String?
  licensePhotoBack   String?
  // DNI
  dniPhotoFront      String?
  dniPhotoBack       String?
  // Psycho exam
  psychoDate       DateTime?
  psychoExpiry     DateTime?
  // Pre-occupational
  preOccupDate     DateTime?
  preOccupResult   String?
  // Labor
  legajo           String?
  hireDate         DateTime?
  position         String?
  agreement        String?
  operativeBase    String?
  status           String    @default("active")
  // Operational
  currentVehicleId String?
  currentVehicle   Vehicle?  @relation(fields: [currentVehicleId], references: [id])
  currentTrailerId String?
  currentTrailer   Trailer?  @relation(fields: [currentTrailerId], references: [id])
  // Relations
  trainings        DriverTraining[]
  history          DriverVehicleHistory[]
  events           DriverEvent[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model DriverTraining {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime?
  expiry    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
}

model DriverVehicleHistory {
  id            String   @id @default(cuid())
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehiclePlate  String?
  trailerDomain String?
  assignedAt    DateTime @default(now())
  assignedBy    String?
  notes         String?
}

model DriverEvent {
  id          String   @id @default(cuid())
  driverId    String
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type        String   // "infraction" | "accident"
  date        DateTime
  description String?  @db.Text
  createdAt   DateTime @default(now())
}
